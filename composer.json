{
    "name": "semitexa/locale",
    "description": "Internationalization (i18n) module for Semitexa Framework",
    "version": "1.0.9",
    "type": "semitexa-module",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "semitexa/core": "^1.0"
    },
    "suggest": {
        "semitexa/tenancy": "Required for TenantResolvedLocaleListener — sets locale from tenant context"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Locale\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Semitexa\\Locale\\Tests\\": "tests/"
        }
    },
    "extra": {
        "semitexa-module": {
            "extends": null
        }
    }
}
